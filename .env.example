# ============================================================
# 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ============================================================

# Django 密钥 (生产环境必须修改)
DJANGO_SECRET_KEY=your-secret-key-here

# 调试模式 (生产环境设为 False)
DJANGO_DEBUG=False

# 允许的主机 (逗号分隔)
DJANGO_ALLOWED_HOSTS=your-server-ip,your-domain.com

# MiMo LLM API Key
LLM_API_KEY=your-mimo-api-key-here

# SSL 重跳转 (如有 HTTPS)
DJANGO_SECURE_SSL=False
